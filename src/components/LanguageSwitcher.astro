---
import { type Locale, getLocalePath } from '../i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const locales = [
  { code: 'en' as const, label: 'EN' },
  { code: 'zh-tw' as const, label: '中文' },
];
---

<nav
  class="fixed top-6 right-6 z-50 flex gap-1 bg-navy-800/80 backdrop-blur-sm border border-teal-400/15 rounded-lg p-1"
  aria-label="Language switcher"
>
  {
    locales.map((locale) => (
      <a
        href={getLocalePath(locale.code)}
        class:list={[
          'px-3 py-1.5 text-sm rounded-md transition-colors duration-200',
          lang === locale.code
            ? 'bg-teal-400 text-navy-900 font-medium'
            : 'text-slate-400 hover:text-slate-100',
        ]}
        aria-current={lang === locale.code ? 'page' : undefined}
      >
        {locale.label}
      </a>
    ))
  }
</nav>
