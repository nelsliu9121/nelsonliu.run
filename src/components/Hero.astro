---
---

<section class="min-h-screen flex items-center justify-center px-6 md:px-10">
  <div class="max-w-5xl w-full flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
    <!-- Text content -->
    <div class="flex-1 max-w-xl text-center lg:text-left">
      <p
        class="font-mono text-teal-400 text-sm md:text-base mb-4 opacity-0 animate-fade-in-up"
      >
        Hi, my name is
      </p>

      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-100 leading-tight mb-2 opacity-0 animate-fade-in-up"
        style="animation-delay: 0.1s"
      >
        Nelson Liu
      </h1>
      <p
        class="text-base text-slate-400 tracking-widest mb-4 opacity-0 animate-fade-in-up"
        style="animation-delay: 0.15s"
      >
        劉于誠
      </p>

      <h2
        class="text-xl md:text-2xl lg:text-3xl font-semibold text-slate-400 mb-6 opacity-0 animate-fade-in-up"
        style="animation-delay: 0.2s"
      >
        I build things for the web.
      </h2>

      <p
        class="text-slate-400 text-base md:text-lg leading-relaxed mb-8 max-w-md mx-auto lg:mx-0 opacity-0 animate-fade-in-up"
        style="animation-delay: 0.3s"
      >
        I'm a web developer specializing in crafting modern, performant web
        experiences and cross-platform mobile applications. I love turning ideas
        into elegant, functional products.
      </p>

      <div
        class="flex flex-wrap gap-4 justify-center lg:justify-start opacity-0 animate-fade-in-up"
        style="animation-delay: 0.4s"
      >
        <a
          href="#skills"
          class="inline-block px-7 py-3 bg-teal-400 text-navy-900 font-medium rounded-md hover:bg-teal-500 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-teal-400/20 transition-all duration-300"
        >
          See what I do
        </a>
        <a
          href="mailto:nelsliu9121@gmail.com"
          class="inline-block px-7 py-3 border border-teal-400 text-teal-400 font-medium rounded-md hover:bg-teal-400/10 hover:-translate-y-0.5 transition-all duration-300"
        >
          Get in touch
        </a>
      </div>
    </div>

    <!-- Code decoration -->
    <div
      class="hidden md:block flex-shrink-0 opacity-0 animate-fade-in-up"
      style="animation-delay: 0.5s"
      aria-hidden="true"
    >
      <div
        class="bg-navy-800 border border-teal-400/15 rounded-xl p-7 font-mono text-sm leading-loose shadow-2xl"
      >
        <div class="flex items-center gap-2 mb-4">
          <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
        </div>
        <code>
          <span class="block"
            ><span class="text-purple-400">const</span>
            <span class="text-blue-400">developer</span> = {'{'}</span
          >
          <span class="block pl-6"
            ><span class="text-slate-300">name</span>:
            <span class="text-teal-400">'Nelson Liu'</span>,</span
          >
          <span class="block pl-6"
            ><span class="text-slate-300">role</span>:
            <span class="text-teal-400">'Web Developer'</span>,</span
          >
          <span class="block pl-6"
            ><span class="text-slate-300">location</span>:
            <span class="text-teal-400">'Taiwan'</span>,</span
          >
          <span class="block pl-6"
            ><span class="text-slate-300">passion</span>:
            <span class="text-teal-400">'Building for the web'</span>,</span
          >
          <span class="block">{'}'};</span>
        </code>
      </div>
    </div>
  </div>
</section>
