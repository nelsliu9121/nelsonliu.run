---
const skills = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" /></svg>`,
    title: 'Front-end',
    description: 'HTML, CSS, JavaScript, TypeScript, React, Vue.js',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>`,
    title: 'Mobile',
    description: 'React Native, cross-platform development, responsive design',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" /></svg>`,
    title: 'Back-end',
    description: 'Node.js, RESTful APIs, databases, cloud services',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" /></svg>`,
    title: 'Tools',
    description: 'Git, CI/CD, Docker, testing frameworks, agile workflow',
  },
];
---

<section id="skills" class="py-20 md:py-28 bg-navy-800">
  <div class="max-w-5xl mx-auto px-6 md:px-10">
    <h2 class="text-2xl md:text-3xl font-bold text-slate-100 text-center mb-3">
      What I Work With
    </h2>
    <div
      class="w-14 h-0.5 bg-teal-400 mx-auto rounded-full mb-4"
      aria-hidden="true"
    >
    </div>
    <p class="text-slate-400 text-center max-w-md mx-auto mb-12 md:mb-16">
      Technologies and tools I use to bring ideas to life
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        skills.map((skill) => (
          <div class="group bg-navy-900 border border-teal-400/[0.08] rounded-xl p-8 text-center transition-all duration-300 hover:-translate-y-1.5 hover:border-teal-400/30 hover:shadow-xl hover:shadow-black/20">
            <div
              class="text-teal-400 mb-5 flex justify-center"
              set:html={skill.icon}
            />
            <h3 class="text-lg font-semibold text-slate-100 mb-2">
              {skill.title}
            </h3>
            <p class="text-sm text-slate-400 leading-relaxed">
              {skill.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
